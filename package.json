{
  "name": "mv-provider",
  "version": "1.0.0",
  "description": "providers for mv-app",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "bun test-providers.js",
    "test:single": "bun test-providers.js",
    "test:provider": "bun test-provider.js",
    "test:ui": "bun run test:interactive",
    "build": "node build-bundled.js",
    "build:dev": "cross-env SKIP_MINIFY=true bun build-bundled.js",
    "dev": "bun dev-server.js",
    "dev:build": "bun run build && bun run dev",
    "watch": "nodemon",
    "watch:dev": "nodemon --watch providers --ext ts --exec \"bun run build\" & bun run dev",
    "dev:auto": "concurrently \"nodemon --watch providers --ext ts --exec \\\"bun run build:dev\\\"\" \"bun run dev\"",
    "auto": "bun auto-dev.js",
    "start": "bun run build && bun run dev",
    "lint:es": "eslint . --ext .ts",
    "lint:ox": "oxlint .",
    "lint": "bun run lint:ox && bun run lint:es",
    "format": "prettier --write \"providers/**/*.ts\""
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/node": "^24.0.1",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.2",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-oxlint": "^1.58.0",
    "eslint-plugin-prettier": "5.1.3",
    "express": "^4.21.2",
    "nodemon": "^3.1.10",
    "oxlint": "^1.58.0",
    "prettier": "3.2.5",
    "terser": "^5.43.1",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "cheerio": "^1.1.0",
    "react-native-aes-crypto": "^3.2.1",
    "rimraf": "^6.0.1",
    "vercel": "^50.40.0",
    "zod": "^4.0.2"
  }
}
